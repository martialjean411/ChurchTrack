<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="160dp"
    android:orientation="horizontal"
    android:padding="20dp"
    android:background="@color/blue_primary"
    android:gravity="center_vertical">

    <FrameLayout
        android:layout_width="52dp"
        android:layout_height="52dp">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="26dp"
            app:cardBackgroundColor="@color/gold"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <TextView
                android:id="@+id/tv_nav_initials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="A"
                android:textSize="20sp"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/playfair_display_bold"
                android:gravity="center" />

        </com.google.android.material.card.MaterialCardView>

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="14dp">

        <TextView
            android:id="@+id/tv_nav_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Administrateur"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:fontFamily="@font/dm_sans_semibold" />

        <TextView
            android:id="@+id/tv_nav_role"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Admin"
            android:textSize="12sp"
            android:textColor="@color/gold_light"
            android:layout_marginTop="2dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ChurchTrack"
            android:textSize="10sp"
            android:textColor="#99FFFFFF"
            android:letterSpacing="0.1"
            android:layout_marginTop="6dp" />

    </LinearLayout>

</LinearLayout>
