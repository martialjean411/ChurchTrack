<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_secondary">

    <!-- Services horizontal list -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cultes récents"
        android:textSize="14sp"
        android:textColor="@color/medium_gray"
        android:textStyle="bold"
        android:padding="16dp"
        android:paddingBottom="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_services"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:clipToPadding="false"
        android:orientation="horizontal" />

    <TextView
        android:id="@+id/tv_no_services"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Aucun culte. Créez-en un ci-dessous."
        android:textSize="14sp"
        android:textColor="@color/medium_gray"
        android:gravity="center"
        android:padding="16dp"
        android:visibility="gone" />

    <!-- Selected service info -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:cardBackgroundColor="@color/white"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/tv_selected_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Sélectionnez un culte ci-dessus"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:gravity="center" />

            <LinearLayout
                android:id="@+id/layout_attendance_actions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:visibility="gone">

                <TextView
                    android:id="@+id/tv_present_count"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="0 présents"
                    android:textSize="18sp"
                    android:textColor="@color/success"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_view_attendees"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:text="Voir liste"
                    android:textSize="12sp"
                    style="@style/Widget.ChurchTrack.Button.Outline"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <!-- Action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:layout_marginTop="8dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_scan_fingerprint"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="👆 Scanner l'empreinte"
            android:textSize="15sp"
            app:backgroundTint="@color/blue_primary"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_fingerprint"
            android:layout_marginBottom="10dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_manual_attendance"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="📋 Saisie manuelle"
            android:textSize="15sp"
            style="@style/Widget.ChurchTrack.Button.Outline"
            app:cornerRadius="10dp"
            android:layout_marginBottom="10dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_new_service"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="+ Nouveau culte"
                android:textSize="13sp"
                app:backgroundTint="@color/gold"
                app:cornerRadius="10dp"
                android:layout_marginEnd="6dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_check_absences"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="⚠️ Vérif. absences"
                android:textSize="13sp"
                style="@style/Widget.ChurchTrack.Button.Outline"
                app:cornerRadius="10dp"
                android:layout_marginStart="6dp" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
