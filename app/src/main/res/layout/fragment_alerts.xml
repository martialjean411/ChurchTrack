<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_secondary">

    <!-- Alert count -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/white"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_alert"
            android:tint="@color/warning"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/tv_alert_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 alerte(s) en attente"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="@font/dm_sans_semibold" />

    </LinearLayout>

    <!-- Tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:tabSelectedTextColor="@color/blue_primary"
        app:tabTextColor="@color/medium_gray"
        app:tabIndicatorColor="@color/gold"
        android:background="@color/white">

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Actives" />

        <com.google.android.material.tabs.TabItem
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Toutes" />

    </com.google.android.material.tabs.TabLayout>

    <TextView
        android:id="@+id/tv_empty_alerts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="✅ Aucune alerte active.\nTous les fidèles sont présents."
        android:textSize="15sp"
        android:textColor="@color/medium_gray"
        android:gravity="center"
        android:padding="48dp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_alerts"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false" />

</LinearLayout>
