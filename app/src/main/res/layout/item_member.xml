<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white"
    android:layout_margin="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp">

            <ImageView
                android:id="@+id/iv_member_photo"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/ic_person"
                android:scaleType="centerCrop" />

            <TextView
                android:id="@+id/tv_initials"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/blue_surface"
                android:gravity="center"
                android:textColor="@color/blue_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_member_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nom Prénom"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/iv_fingerprint"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_fingerprint"
                    android:tint="@color/blue_primary"
                    android:layout_marginStart="6dp"
                    android:visibility="gone" />

            </LinearLayout>

            <TextView
                android:id="@+id/tv_member_contact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+225 00 00 00 00"
                android:textSize="12sp"
                android:textColor="@color/medium_gray"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tv_member_gender"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Homme"
                android:textSize="11sp"
                android:textColor="@color/blue_secondary"
                android:layout_marginTop="2dp" />

        </LinearLayout>

        <!-- Actions -->
        <ImageButton
            android:id="@+id/btn_edit"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_edit"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/medium_gray"
            android:contentDescription="Modifier" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
